# Required: Postgres connection string (Neon in prod).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require&uselibpqcompat=true"

# Required: 32+ char random secret used to encrypt stored integration secrets
# (Resend / Beehiiv / Substack keys) at rest with AES-256-GCM. The same value
# must be used in every environment that reads the same database row, otherwise
# the existing rows become unreadable. Generate with: openssl rand -hex 32
MAGNETS_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Optional: canonical base URL used for canonical tags, robots.txt, sitemap,
# and the dashboard's "View on magnets.so" platform fallback link.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Vercel Domains API integration for automatic attach/detach of
# customer-owned domains. If unset, account saves still succeed but Vercel
# domains must be added manually. Create the token at vercel.com/account/tokens.
# VERCEL_API_TOKEN=""
# VERCEL_PROJECT_ID="prj_..."
# VERCEL_TEAM_ID="team_..."
