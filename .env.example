# Required: Postgres connection string (Neon in prod).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require&uselibpqcompat=true"

# Required: 32+ char random secret used to encrypt stored integration secrets
# (Resend / Beehiiv / Substack keys) at rest with AES-256-GCM. The same value
# must be used in every environment that reads the same database row, otherwise
# the existing rows become unreadable. Generate with: openssl rand -hex 32
MAGNETS_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# Optional: canonical base URL used for canonical tags, robots.txt, sitemap,
# and the dashboard's "View on magnets.so" platform fallback link.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Magnets-managed Resend account. When set, users can send and run
# follow-up sequences without providing their own Resend API key. This must be
# a Full-access key from the Magnets Resend account, never a NEXT_PUBLIC value.
# MAGNETS_RESEND_API_KEY="re_..."
# Optional override for the Magnets sender. Defaults to Magnets <hello@mail.magnets.so>.
# MAGNETS_RESEND_FROM_EMAIL="Magnets <hello@mail.magnets.so>"

# Optional: server-only DeepSeek key for the "Write with AI" page-creation flow.
# The generator uses deepseek-v4-pro. Never expose this with NEXT_PUBLIC_.
# DEEPSEEK_API_KEY="sk-..."

# Optional: Vercel Blob credentials for uploaded lead-magnet images.
# Newer connected stores use OIDC with BLOB_STORE_ID and BLOB_WEBHOOK_PUBLIC_KEY.
# Older stores may provide BLOB_READ_WRITE_TOKEN instead.
# BLOB_STORE_ID="store_..."
# BLOB_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: Vercel Domains API integration for automatic attach/detach of
# customer-owned domains. If unset, account saves still succeed but Vercel
# domains must be added manually. Create the token at vercel.com/account/tokens.
# VERCEL_API_TOKEN=""
# VERCEL_PROJECT_ID="prj_..."
# VERCEL_TEAM_ID="team_..."

# Optional: Magnets product newsletter list. Used to subscribe new registrants
# after they tick the "I accept the Terms of Service" box on /register.
# Without these, registration still succeeds but the subscribe is skipped.
# PLATFORM_BEEHIIV_API_KEY=""
# PLATFORM_BEEHIIV_PUBLICATION_ID="pub_..."
